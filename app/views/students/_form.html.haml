-# student form html
-# frozen_string_literal: true
= simple_form_for(@student) do |f|
  .card-body
    = f.input :forename, wrapper_html: { class: 'mb-3' }
    = f.input :surname, wrapper_html: { class: 'mb-3' }
    = f.input :regID, wrapper_html: { class: 'mb-3' }
    = f.input :status, wrapper_html: { class: 'mb-3' }
    = f.input :program_id, wrapper_html: { class: 'mb-3' }
      
  .card-footer.d-flex
    %button.btn.btn-primary.bg-uospurple{ type: 'submit' }
      Save
    = link_to 'Back', students_path, class: 'btn btn-link ms-auto'