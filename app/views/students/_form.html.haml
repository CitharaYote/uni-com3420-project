-# student form html
-# frozen_string_literal: true
= simple_form_for(@student) do |f|
  .card-body
    = f.input :forename, wrapper_html: { class: 'mb-3' }
    = f.input :surname, wrapper_html: { class: 'mb-3' }
    = f.input :regID, wrapper_html: { class: 'mb-3' }, label: "Registration ID"
    = f.input :status, wrapper_html: { class: 'mb-3' }
    = f.input :program_id, wrapper_html: { class: 'mb-3' }, label: "Programme", collection: Program.order('program_name').map { |program| [program.program_name, program.id] }, include_blank: false
      
  .card-footer.d-flex
    %button{ type: 'submit', class: "bg-uospurple text-white px-4 py-2 rounded-lg hover:bg-opacity-70 transition" }
      Save
    = link_to 'Back', students_path, class: 'bg-gray-200 text-gray-700 px-4 py-2 rounded-lg hover:tw-bg-secondary hover:text-white transition ms-auto'