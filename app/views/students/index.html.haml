.card
  .card-header.d-flex.align-items-center
    %span Listing Students

    = link_to 'New Student', new_student_path, class: 'btn btn-outline-secondary ms-auto'
    = render "students/import_form"

  %table.table
    %thead
      %tr
        %th regID
        %th Programme
        %th status
         
    %tbody
      - @students.each do |student|
        %tr
          %td= student.regID
          %td= student.status
          %td
            .btn-toolbar.float-end
              = link_to 'Show', student, class: 'btn btn-outline-secondary btn-sm'
              = link_to 'Edit', edit_student_path(student), class: 'btn btn-outline-secondary ms-1 btn-sm'
              = link_to 'Destroy', student, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-outline-danger ms-1 btn-sm'