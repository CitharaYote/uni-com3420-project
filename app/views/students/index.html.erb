<div class = "card">
  <div class = "card-header d-flex align-items-center">
    <span>
      Listing Students
    </span>
    <span class="ms-1">
      (<%=@students.size%>)
    </span>
    <%= render "students/import_form" %>
    <div>
      <%# make the dropdown unique here %>
      <%= form_tag students_path, method: :get do %>
        <%= select_tag :program, options_for_select(Program.all.map{ |p| [p.program_name, p.id] }, params[:program]), include_blank: 'Filter By Programme' %>
        <%= select_tag :status, options_for_select(Student.all.map{ |i| [i.status, i.id] }, params[:status]),unique: true , include_blank: 'Filter By Status' %>
        <%= button_tag "Filter", class: "btn btn-primary bg-uospurple", type: "submit" %>
      <% end %>
    </div>
    <a href="/students/new" class="btn btn-outline-secondary ms-auto">New Student</a>
  </div>
  <div class="card-body">
  <%= simple_form_for :search, url: search_students_path, method: :post do |f| %>
    <div class="mb-3">
      <%= f.input :regID %>
      
    </div>
    <div class="btn-toolbar">
      <%= f.submit 'Search', class: 'btn btn-outline-secondary' %>
      <%= link_to 'Reset', students_path, class: 'btn btn-link ms-1' %>
    </div>
  <% end %>
  </div>
  <div class="body">
      

      <table class="table">
        <thead style="background-color: lightblue;">
          <th>
            Program_name
          </th>
          <th>
            Forename
          </th>
          <th>
            Surname
          </th>
          <th>
            RegID
          </th>
          <th>
            Status
          </th>
          <th>
            Option
          </th>
        </thead>
        <tbody>
          <% @students.each do |student|%>
            <tr>
              <td><%= student.program_name %></td>
              <td><%= student.forename %></td>
              <td><%= student.surname %></td>
              <td><%= student.regID %></td>
              <td>
              <% if student.status == "nc" %>
              Not Completed
              <% elsif student.status == "na" %>
              Not Assessed
              <% elsif student.status == "fail"%>
              failed
              <% end %>
              </td>
              <td>
                <a href="course_detail?id=<%= student.id %>">course detail</a>
                <%= link_to 'Destroy', student, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-outline-danger ms-1 btn-sm' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
  </div>
  

</div>
