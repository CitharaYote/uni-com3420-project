.card
  .card-header.d-flex.align-items-center
    %span Listing Programs

    = link_to 'New Program', new_program_path, class: 'btn btn-outline-secondary ms-auto'

  %table.table
    %thead
      %tr
        %th Program Code
        %th Program Title
        %th
    %tbody
      - @programs.each do |program|
        %tr
          %td= program.program_name
          %td= program.id
          %td
            .btn-toolbar.float-end
              = link_to 'Show', program, class: 'btn btn-outline-secondary btn-sm'
              = link_to 'Edit', edit_program_path(program), class: 'btn btn-outline-secondary ms-1 btn-sm'
              = link_to 'Destroy', program, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-outline-danger ms-1 btn-sm'