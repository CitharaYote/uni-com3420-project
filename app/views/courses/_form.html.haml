-# frozen_string_literal: true
-# Form HAML HTML for Courses
= simple_form_for(@course) do |f|
  .card-body
    = f.input :module_code, wrapper_html: { class: 'mb-3' }
    = f.input :credit, wrapper_html: { class: 'mb-3' }

  .card-footer.d-flex
    %button.btn.btn-primary.bg-uospurple{ type: 'submit', class: "bg-uospurple text-white px-4 py-2 rounded-lg hover:bg-opacity-70 transition" }
      Save
    = link_to 'Back', courses_path, class: 'bg-gray-200 text-gray-700 px-4 py-2 rounded-lg hover:tw-bg-secondary hover:text-white transition ms-auto'
