.card
  .card-header.d-flex.align-items-center
    = form_tag courses_path, method: :get do
      = label_tag :filter, "Filter Courses By Programme"
      = select_tag :program, options_for_select(Program.all.map{ |p| [p.program_name, p.id] }, params[:program]), include_blank: true
      %button.btn.btn-primary.bg-uospurple{ type: 'submit' }
        Filter
    
    = link_to 'New Course', new_course_path, class: 'btn btn-outline-secondary ms-auto'

  %table.table
    %thead
      %tr
        %th Course code
        %th Credit
        %th ID
        %th
    %tbody
      - @courses.each do |course|
        %tr
          %td= course.module_code
          %td= course.credit
          %td= course.id
          %td
            .btn-toolbar.float-end
              = link_to 'Show', course, class: 'btn btn-outline-secondary btn-sm'
              = link_to 'Edit', edit_course_path(course), class: 'btn btn-outline-secondary ms-1 btn-sm'
              = link_to 'Destroy', course, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-outline-danger ms-1 btn-sm'