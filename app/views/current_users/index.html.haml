.row.justify-content-center
  .col-sm-8.col-lg-6
    .card
      .card-header
        User Profile
      .card-body
        %dl.row.mb-0
          %dt.col-md-3 Username:
          %dd.col-md-9= link_to current_user.username
          %dt.col-md-3 Email:
          %dd.col-md-9= link_to current_user.email
          %dt.col-md-3 First name:
          %dd.col-md-9= link_to current_user.givenname
          %dt.col-md-3 Last name:
          %dd.col-md-9= link_to current_user.sn
          %dt.col-md-3 Administrator status:
          %dd.col-md-9= link_to staff.is_admin
      .card-footer.d-flex
        = link_to 'Back', "/", class: 'btn btn-link ms-auto'