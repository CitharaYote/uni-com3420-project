- content_for :title, 'Log In'

.justify-content-center.mt-16.flex.flex-row
  .col-sm-6.col-lg-4
    .card.card-light
      = simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f|
        .card-header
          Log In
        .card-body
          = f.input :username, autofocus: true, required: true
          = f.input :password, required: true
        .card-footer
          %button.btn.btn-primary.bg-uospurple{ type: :submit, class: "bg-uospurple" }
            Log in
          .mt-3= render "devise/shared/links"