.card
  .card-header.d-flex.align-items-center
    %span Listing Items

    = link_to 'New Item', new_item_path, class: 'btn btn-outline-secondary ms-auto'
    = render "items/import_form"

  %table.table
    %thead
      %tr
        %th Name
        %th Value
        %th
    %tbody
      - @items.each do |item|
        %tr
          %td= item.name
          %td= item.value
          %td
            .btn-toolbar.float-end
              = link_to 'Show', item, class: 'btn btn-outline-secondary btn-sm'
              = link_to 'Edit', edit_item_path(item), class: 'btn btn-outline-secondary ms-1 btn-sm'
              = link_to 'Destroy', item, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-outline-danger ms-1 btn-sm'