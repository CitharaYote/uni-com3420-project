-# staff form html
-# frozen_string_literal: true
= simple_form_for(@staff) do |f|
  - if can? :manage, Staff
    .card-body
      = f.input :username, wrapper_html: { class: 'mb-3' }
      = f.input :is_admin, wrapper_html: { class: 'mb-3' }

    .card-footer.d-flex
      %button.btn.btn-primary.bg-uospurple{ type: 'submit' }
        Save
      = link_to 'Back', staffs_path, class: 'btn btn-link ms-auto'
