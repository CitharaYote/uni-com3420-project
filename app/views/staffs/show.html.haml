-# staff show html
.row.justify-content-center
  .col-sm-8.col-lg-6
    .card
      .card-header.flex.flex-row.tw-items-center.py-4
        %p.text-2xl.text-gray-700
          Staff Details
      .body.p-4
        - if can? :manage, Staff
          %dl.row.mb-0
            %dt.col-md-3 Username:
            %dd.col-md-9= @staff.username
            %dt.col-md-3 Admin:
            %dd.col-md-9= @staff.is_admin
      
      .card-footer.d-flex
        - if can? :manage, Staff
          = link_to 'Edit', edit_staff_path(@staff), class: 'bg-uospurple text-white px-4 py-2 rounded-lg hover:bg-opacity-70 transition'
        = link_to 'Back', staffs_path, class: 'bg-gray-200 text-gray-700 px-4 py-2 rounded-lg hover:tw-bg-secondary hover:text-white transition ms-auto'