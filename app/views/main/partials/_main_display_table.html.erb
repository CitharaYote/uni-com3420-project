        <% @students.each do |student|%>
          <tr class="transition cursor-pointer odd:bg-gray-100 even:bg-white hover:bg-gray-200" onclick=<%= "window.location.href='/students/#{student.id}';" %>>
            <td class="px-4 py-2 border"><%= student.regID %></td>
            <td class="px-4 py-2 border"><%= student.program_name %></td>
            <div>
            <% @course_list.each do|course| %>
              <% if Mark.find_by(student_id: student.id, course_id: Course.find_by(module_code: course)).present? %>
                <td class="px-4 py-2 border"><%= Mark.find_by(student_id: student.id, course_id: Course.find_by(module_code: course)).final_score %></td>
              <% else %>
                <td class = "px-4 py-2 border">-</td>
              <% end %>
            <% end %>
            </div>
            <td class="px-4 py-2 border"><%= student.wmg_calculator.round(2) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
